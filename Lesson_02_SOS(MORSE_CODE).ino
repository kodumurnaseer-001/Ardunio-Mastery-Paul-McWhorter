int pin13=13;
int dt1=50;
int dt2=500;
int dt=1000;
void setup(){
  pinMode(pin13,OUTPUT);
}
void loop(){
  digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt1);
digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt1);
digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt1);
digitalWrite(pin13,HIGH);
delay(dt2);
digitalWrite(pin13,LOW);
delay(dt2);
digitalWrite(pin13,HIGH);
delay(dt2);
digitalWrite(pin13,LOW);
delay(dt2);
digitalWrite(pin13,HIGH);
delay(dt2);
digitalWrite(pin13,LOW);
delay(dt2);
digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt1);
digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt1);
digitalWrite(pin13,HIGH);
delay(dt1);
digitalWrite(pin13,LOW);
delay(dt);
}




